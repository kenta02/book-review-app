{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "dev": "ts-node --transpileOnly ./src/server.ts",
    "swagger": "ts-node --transpileOnly ./src/swagger-server.ts",
    "token": "ts-node ./scripts/get-token.ts",
    "db:migrate": "ts-node ./scripts/run-migrations.ts up",
    "db:migrate:down": "ts-node ./scripts/run-migrations.ts down",
    "db:migrate:status": "ts-node ./scripts/run-migrations.ts status",
    "db:migrate:pending": "ts-node ./scripts/run-migrations.ts pending",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ci": "vitest --run",
    "test:ci-parity": "DB_NAME=test_db DB_USER=test_user DB_PASS=test_pass DB_HOST=127.0.0.1 DB_PORT=1 JWT_SECRET=test-jwt-secret vitest --run --coverage",
    "coverage": "vitest --coverage",
    "coverage:ci": "vitest --run --coverage",
    "lint": "eslint 'src/**/*.{ts,tsx}' --ext .ts",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --ext .ts --fix",
    "format": "prettier --write .",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "seed-demo": "ts-node ./scripts/seed-demo.ts",
    "seed-tanaka": "ts-node ./scripts/seed-tanaka.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-gnu": "^1.0.0-rc.12"
  },
  "dependencies": {
    "bcrypt": "6.0.0",
    "cors": "2.8.6",
    "dotenv": "17.2.3",
    "express": "5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "9.0.3",
    "mysql2": "3.20.0",
    "sequelize": "6.37.8",
    "swagger-ui-express": "5.0.0",
    "yaml": "^2.4.1"
  },
  "devDependencies": {
    "@eslint/js": "8.57.1",
    "@rolldown/binding-linux-x64-gnu": "^1.0.0-rc.12",
    "@types/bcrypt": "6.0.0",
    "@types/cors": "2.8.19",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.5.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.58.0",
    "@vitest/coverage-v8": "4.1.2",
    "eslint": "8.57.1",
    "eslint-config-prettier": "^8.8.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "nodemon": "3.1.14",
    "prettier": "^3.8.0",
    "sqlite3": "^6.0.1",
    "supertest": "^7.2.2",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "typedoc": "^0.28.18",
    "typescript": "5.9.3",
    "umzug": "^3.1.0",
    "vitest": "4.1.2"
  }
}
